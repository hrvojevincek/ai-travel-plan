# Auth (better-auth)
BETTER_AUTH_SECRET=

# Database (Postgres / Neon)
DATABASE_URL=

# AI SDK
OPENAI_API_KEY=

# Upstash (rate limit — KRE-28). If unset, /api/trips/generate is unlimited.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Maps — two keys:
# - Server key for Geocoding API (KRE-29). If unset, activities save without pins.
GOOGLE_MAPS_SERVER_KEY=
# - Browser key for Maps JavaScript API + Places Autocomplete (KRE-29).
#   HTTP-referrer restricted in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# - Map ID (Google Cloud Console → Maps → Map Styles). Required for
#   AdvancedMarker + styled maps; without it, markers fall back to the
#   legacy red-pin API.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
