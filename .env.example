# Auth (better-auth)
BETTER_AUTH_SECRET=

# Database (Postgres / Neon)
DATABASE_URL=

# AI SDK
OPENAI_API_KEY=

# Upstash (rate limit — KRE-28). If unset, /api/trips/generate is unlimited.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Places (map display uses mapcn / MapLibre — no API key needed)
# - Server key for Places/Geocoding server calls (find-place + popup photo proxy).
#   If unset, activities save without reliable pins/photos.
GOOGLE_MAPS_SERVER_KEY=
# - Browser key for Places Autocomplete on the home search form (KRE-29).
#   HTTP-referrer restricted in Google Cloud Console. Map works without it.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# - Secret for short-lived HMAC signatures used by /api/maps/photo proxy.
#   Required for place photos in map popups. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MAPS_PHOTO_SECRET=
